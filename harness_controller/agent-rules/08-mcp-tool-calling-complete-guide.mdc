## Complete Example: Call retrieve_memory_by_chunks

```powershell
# 1. Get harness response with MCP request
$session = .\harness\invoke-harness-control-plane.ps1 get-next-step -SessionId $sid
$mcp_request = $session.payload.request

# 2. Build JSON-RPC envelope
$jsonRpcBody = @{
    jsonrpc = "2.0"
    id = 1
    method = "tools/call"
    params = @{
        name = "retrieve_memory_by_chunks"
        arguments = $mcp_request
    }
} | ConvertTo-Json -Depth 20

# 3. Call MCP server
$response = Invoke-WebRequest `
    -Uri "http://127.0.0.1:5081/" `
    -Method Post `
    -ContentType "application/json" `
    -Headers @{ "Accept" = "application/json, text/event-stream" } `
    -Body $jsonRpcBody `
    -UseBasicParsing `
    -TimeoutSec 30

# 4. Parse SSE response
$raw = $response.Content
$dataLine = ($raw -split "`n") | Where-Object { $_ -match "^data:" } | Select-Object -First 1
$json = $dataLine -replace "^data:\s*", ""
$mcp_response = $json | ConvertFrom-Json

# 5. Save and submit
$mcp_response | ConvertTo-Json -Depth 30 | Out-File "mcp_response.json"

.\harness\invoke-harness-control-plane.ps1 submit-step-result `
    -SessionId $sid `
    -Action "agent_call_mcp_retrieve_memory_by_chunks" `
    -ArtifactType "MCP.RetrieveMemoryByChunksResponse" `
    -ArtifactFile "mcp_response.json"
```

